# Public app URL (без завершающего /)
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# Telegram bot + webhook
TELEGRAM_BOT_TOKEN=123456:ABCDEF
# Optional explicit client ID for the new browser Telegram Login flow.
# If empty, the server falls back to the numeric bot ID from TELEGRAM_BOT_TOKEN.
TELEGRAM_LOGIN_CLIENT_ID=123456789
# Optional public mirror of client ID if you want to expose it directly in the frontend.
# NEXT_PUBLIC_TELEGRAM_LOGIN_CLIENT_ID=123456789
# Optional bot username for deep links and bot references.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBHOOK_SECRET=change_me_webhook_secret
TELEGRAM_WEBHOOK_BASE_URL=https://your-project.vercel.app
TELEGRAM_ADMIN_KEY=change_me_admin_key

# Telegram worker / cron auth
TELEGRAM_WORKER_SECRET=change_me_worker_secret
C3K_STORAGE_WORKER_SECRET=change_me_storage_worker_secret
C3K_STORAGE_WORKER_BASE_URL=http://127.0.0.1:3000
# External upload bridge for real TON Storage test runtime:
# - simulated: keeps current local/test contour
# - tonstorage_cli: local worker calls storage-daemon-cli and returns a real BagID
C3K_STORAGE_TON_UPLOAD_BRIDGE_MODE=simulated
# Path to storage-daemon-cli when using tonstorage_cli
C3K_STORAGE_TON_DAEMON_CLI_BIN=storage-daemon-cli
# Optional JSON array with extra CLI args, for example:
# C3K_STORAGE_TON_DAEMON_CLI_ARGS_JSON=["-I","127.0.0.1:5555","-k","/path/client","-p","/path/server.pub"]
C3K_STORAGE_TON_DAEMON_CLI_ARGS_JSON=[]
# Optional HTTP gateway used by web/Telegram delivery to resolve tonstorage:// pointers back into downloadable files
# Example: http://127.0.0.1:8080/tonstorage
C3K_STORAGE_TON_HTTP_GATEWAY_BASE=
# Optional local desktop node metadata and storage root used by Sprint 11 runtime/heartbeat
# C3K_STORAGE_LOCAL_NODE_STORAGE_ROOT=/absolute/path/to/storage-db
C3K_STORAGE_LOCAL_NODE_STORAGE_ROOT=
# C3K_STORAGE_LOCAL_NODE_PUBLIC_LABEL=Roman desktop node
C3K_STORAGE_LOCAL_NODE_PUBLIC_LABEL=
C3K_STORAGE_LOCAL_NODE_CITY=
C3K_STORAGE_LOCAL_NODE_COUNTRY_CODE=
C3K_STORAGE_LOCAL_NODE_LATITUDE=
C3K_STORAGE_LOCAL_NODE_LONGITUDE=
# Preview bandwidth for node participation / registry heartbeat
C3K_STORAGE_LOCAL_NODE_BANDWIDTH_KBPS=25000
# Local Telegram delivery loop for desktop-node mode
C3K_STORAGE_LOCAL_DELIVERY_WORKER_ENABLED=1
# Optional local worker tuning
# C3K_LOCAL_RUNTIME_BASE_URL=http://127.0.0.1:3000
# C3K_LOCAL_DELIVERY_WORKER_LIMIT=6
# C3K_LOCAL_DELIVERY_WORKER_INTERVAL_MS=12000
CRON_SECRET=change_me_cron_secret

# Admin access (CSV Telegram IDs)
SHOP_ADMIN_TELEGRAM_IDS=1693883
NEXT_PUBLIC_SHOP_ADMIN_TELEGRAM_IDS=1693883

# Postgres (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Optional fallback for project ref if SUPABASE_URL not provided
# SUPABASE_PROJECT_REF=your_project_ref

# Production hardening
POSTGRES_STRICT_MODE=1

# Optional: rate-limit/idempotency/queue persistence via Upstash
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Optional tuning
TELEGRAM_INITDATA_MAX_AGE_SECONDS=300
TELEGRAM_LOGIN_MAX_AGE_SECONDS=86400
BROWSER_AUTH_SESSION_TTL_SECONDS=2592000
SHOP_AUTH_SESSION_SECRET=change_me_session_secret
TELEGRAM_QUEUE_INLINE_PROCESSING=1
TELEGRAM_QUEUE_INLINE_LIMIT=5

# TON Connect / crypto top-up / NFT mint
# Network mode: testnet | mainnet
NEXT_PUBLIC_TON_NETWORK=testnet
# Enable only after NFT collection + sponsor wallet are configured for the selected network.
NEXT_PUBLIC_TON_ONCHAIN_NFT_MINT_ENABLED=0
# In testnet you can keep addresses empty and use self-recipient fallback.
NEXT_PUBLIC_TON_TESTNET_SELF_RECIPIENT_FALLBACK=1
NEXT_PUBLIC_TON_TOPUP_ADDRESS=
NEXT_PUBLIC_TON_NFT_COLLECTION_ADDRESS=
# Exact string written into NFT item individual content.
# Default (if empty): https://<public-app-url>/api/ton/nft/metadata/releases/
# You can use {slug}, for example:
# TON_NFT_ITEM_CONTENT_PREFIX=https://your-project.vercel.app/api/ton/nft/metadata/releases/{slug}
# Or a relative prefix if the collection already has a common off-chain prefix on-chain.
# TON_NFT_ITEM_CONTENT_PREFIX=releases/{slug}
NEXT_PUBLIC_TON_TOPUP_STARS_CENTS_PER_TON=12000
# Total TON sponsor wallet sends to the collection during mint.
NEXT_PUBLIC_TON_MINT_FEE_NANO=50000000
# TON forwarded from collection to the newly deployed NFT item.
TON_NFT_ITEM_FORWARD_VALUE_NANO=30000000

# TON sponsored mint relay (server-side)
# 24-word mnemonic for relayer wallet. For reference NFT collection it must be the collection owner wallet.
TON_SPONSOR_WALLET_MNEMONIC=
# Optional explicit sponsor address (for logs/UX). If empty, derived from mnemonic.
TON_SPONSOR_WALLET_ADDRESS=
# User pays this fee from internal balance when triggering sponsored mint.
TON_SPONSORED_MINT_GAS_STARS_CENTS=2500
# Optional custom TON center endpoints
# TON_TESTNET_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
# TON_MAINNET_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
# Optional TON Center API key
# TONCENTER_API_KEY=
# Relay confirmation wait timeout (ms)
TON_SPONSOR_CONFIRMATION_TIMEOUT_MS=12000
# TON value sent once to deploy the NFT collection contract.
TON_COLLECTION_DEPLOY_VALUE_NANO=200000000

# C3K Storage / Desktop / TON Site
# Master feature flag for storage program and registry-backed APIs
NEXT_PUBLIC_C3K_STORAGE_ENABLED=0
C3K_STORAGE_ENABLED=0
# Desktop client rollout flags
NEXT_PUBLIC_C3K_STORAGE_DESKTOP_CLIENT_ENABLED=0
C3K_STORAGE_DESKTOP_CLIENT_ENABLED=0
NEXT_PUBLIC_C3K_TON_SITE_DESKTOP_GATEWAY_ENABLED=0
C3K_TON_SITE_DESKTOP_GATEWAY_ENABLED=0
# Desktop runtime contract
NEXT_PUBLIC_C3K_DESKTOP_APP_SCHEME=c3k
C3K_DESKTOP_APP_SCHEME=c3k
NEXT_PUBLIC_C3K_DESKTOP_GATEWAY_HOST=127.0.0.1
C3K_DESKTOP_GATEWAY_HOST=127.0.0.1
NEXT_PUBLIC_C3K_DESKTOP_GATEWAY_PORT=3467
C3K_DESKTOP_GATEWAY_PORT=3467
NEXT_PUBLIC_C3K_DESKTOP_TON_SITE_HOST=c3k.ton
C3K_DESKTOP_TON_SITE_HOST=c3k.ton
# Optional desktop start URL override. Default: <public-app-url>/storage/desktop
# C3K_DESKTOP_START_URL=https://your-project.vercel.app/storage/desktop
# Allow Telegram bot to deliver purchased files from storage layer
C3K_STORAGE_TELEGRAM_BOT_DELIVERY_ENABLED=0
# Enable test-only ingest pipeline that prepares placeholder bags without real TON Storage costs
C3K_STORAGE_TEST_MODE_INGEST_ENABLED=1
# Runtime mode for storage ingest:
# - test_prepare: local/test-only placeholder bags
# - tonstorage_testnet: testnet-style pointers and bag metadata for future daemon bridge
NEXT_PUBLIC_C3K_STORAGE_RUNTIME_MODE=test_prepare
C3K_STORAGE_RUNTIME_MODE=test_prepare
# Base prefix used to build testnet-style storage pointers before real daemon upload is connected
C3K_STORAGE_TON_TESTNET_POINTER_BASE=tonstorage://testnet/c3k-runtime
# Human label for the provider/runtime shown in admin and user storage UIs
C3K_STORAGE_TON_TESTNET_PROVIDER_LABEL=C3K Testnet Provider
